+++ b/packages/rainbowkit/src/components/ConnectOptions/MobileOptions.tsx
@@ -83,6 +83,18 @@ export function WalletButton({
   const { i18n } = useContext(I18nContext);
 
   const onConnect = useCallback(async () => {
+    // OpenLV manages its own modal UI, so close RainbowKit modal immediately
+    // and let the connector handle the connection flow
+    if (id === 'openLv') {
+      onClose?.();
+      try {
+        await connect?.();
+      } catch {
+        // Ignore connection errors (e.g. user dismissed OpenLV modal)
+      }
+      return;
+    }
+
     const onMobileUri = async () => {
       const mobileUri = await getMobileUri?.();
 
